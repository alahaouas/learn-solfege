# ============================================================
# SolfApp — Variables d'environnement locales
# ============================================================
# Copier ce fichier vers .env.local et renseigner les valeurs.
# NE JAMAIS committer .env.local (il est dans .gitignore).
#
# Où trouver les valeurs Supabase :
#   → https://supabase.com/dashboard → votre projet → Settings → API
# ============================================================

# --- Supabase (obligatoire pour l'auth et la persistence cloud) ---
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# --- Optionnel : URL publique de l'app (pour les redirections OAuth) ---
# VITE_APP_URL=http://localhost:5173

# ============================================================
# Développement local avec Supabase CLI
# ============================================================
# Si vous utilisez `supabase start` (Supabase local) :
#
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_ANON_KEY=<clé affichée par `supabase status`>
#
# Prérequis : Docker + Supabase CLI installés
#   npm install -g supabase
#   supabase start
#   supabase db push   # applique les migrations
# ============================================================
